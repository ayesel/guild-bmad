{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "primitive": {
    "color": {
      "slate-950": { "$type": "color", "$value": "#111827" },
      "slate-800": { "$type": "color", "$value": "#1f2937" },
      "slate-700": { "$type": "color", "$value": "#374151" },
      "slate-600": { "$type": "color", "$value": "#4b5563" },
      "slate-200": { "$type": "color", "$value": "#e5e7eb" },
      "slate-100": { "$type": "color", "$value": "#f3f4f6" },
      "white": { "$type": "color", "$value": "#ffffff" },
      "green-700": { "$type": "color", "$value": "#047857" },
      "green-100": { "$type": "color", "$value": "#d1fae5" },
      "lime-400": { "$type": "color", "$value": "#a3e635" },
      "amber-500": { "$type": "color", "$value": "#f59e0b" },
      "amber-100": { "$type": "color", "$value": "#fef3c7" },
      "rose-600": { "$type": "color", "$value": "#e11d48" },
      "blue-600": { "$type": "color", "$value": "#2563eb" },
      "blue-100": { "$type": "color", "$value": "#dbeafe" }
    },
    "dimension": {
      "0": { "$type": "dimension", "$value": "0" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "20px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "10": { "$type": "dimension", "$value": "40px" },
      "12": { "$type": "dimension", "$value": "48px" },
      "16": { "$type": "dimension", "$value": "64px" },
      "24": { "$type": "dimension", "$value": "96px" },
      "32": { "$type": "dimension", "$value": "128px" }
    },
    "font": {
      "sans": { "$type": "fontFamily", "$value": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif" }
    },
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "base": { "$type": "duration", "$value": "180ms" },
      "slow": { "$type": "duration", "$value": "260ms" }
    },
    "easing": {
      "signature": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] }
    }
  },
  "semantic": {
    "color": {
      "bg": { "$type": "color", "$value": "{primitive.color.slate-100}" },
      "surface": { "$type": "color", "$value": "{primitive.color.white}" },
      "surface-muted": { "$type": "color", "$value": "{primitive.color.slate-100}" },
      "surface-strong": { "$type": "color", "$value": "{primitive.color.slate-950}" },
      "text": { "$type": "color", "$value": "{primitive.color.slate-950}" },
      "text-muted": { "$type": "color", "$value": "{primitive.color.slate-600}" },
      "border": { "$type": "color", "$value": "{primitive.color.slate-200}" },
      "focus": { "$type": "color", "$value": "{primitive.color.blue-600}" },
      "primary": { "$type": "color", "$value": "{primitive.color.green-700}" },
      "primary-subtle": { "$type": "color", "$value": "{primitive.color.green-100}" },
      "accent": { "$type": "color", "$value": "{primitive.color.lime-400}" },
      "warning": { "$type": "color", "$value": "{primitive.color.amber-500}" },
      "warning-subtle": { "$type": "color", "$value": "{primitive.color.amber-100}" },
      "danger": { "$type": "color", "$value": "{primitive.color.rose-600}" },
      "info-subtle": { "$type": "color", "$value": "{primitive.color.blue-100}" }
    },
    "space": {
      "xs": { "$type": "dimension", "$value": "{primitive.dimension.1}" },
      "sm": { "$type": "dimension", "$value": "{primitive.dimension.2}" },
      "md": { "$type": "dimension", "$value": "{primitive.dimension.4}" },
      "lg": { "$type": "dimension", "$value": "{primitive.dimension.6}" },
      "xl": { "$type": "dimension", "$value": "{primitive.dimension.8}" },
      "2xl": { "$type": "dimension", "$value": "{primitive.dimension.12}" },
      "3xl": { "$type": "dimension", "$value": "{primitive.dimension.16}" }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": "{primitive.dimension.2}" },
      "md": { "$type": "dimension", "$value": "{primitive.dimension.3}" },
      "lg": { "$type": "dimension", "$value": "{primitive.dimension.4}" }
    },
    "motion": {
      "duration-fast": { "$type": "duration", "$value": "{primitive.duration.fast}" },
      "duration-base": { "$type": "duration", "$value": "{primitive.duration.base}" },
      "duration-slow": { "$type": "duration", "$value": "{primitive.duration.slow}" },
      "ease-signature": { "$type": "cubicBezier", "$value": "{primitive.easing.signature}" }
    }
  }
}

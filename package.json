{
  "name": "@ayesel/guild",
  "version": "0.1.0",
  "description": "AI-powered product design framework \u2014 8 specialized design agents (research, interaction, visual, content, QA, dev handoff, design systems, information architecture) plus an orchestrator. Works standalone or with BMAD v6.",
  "bin": {
    "guild": "bin/guild.js"
  },
  "files": [
    ".claude/",
    ".cursor/",
    ".gemini/",
    "_bmad/",
    "bin/",
    "bmad-bundle/",
    "docs/",
    "guild.config.yaml",
    "mcp/",
    "scripts/ab-eval.py",
    "scripts/artifact-model.py",
    "scripts/bradley-terry.py",
    "scripts/build-context.py",
    "scripts/cd-handoff-gate.py",
    "scripts/cd-tokens-to-dtcg.py",
    "scripts/composers.py",
    "scripts/confidence-gate.py",
    "scripts/dtcg-export.py",
    "scripts/fidelity-gate.py",
    "scripts/guild-canvas.py",
    "scripts/guild-prototype-lane.py",
    "scripts/handoff-adapter.py",
    "scripts/ia-evidence-guard.py",
    "scripts/install.sh",
    "scripts/judge-calibration.py",
    "scripts/layout-engine.py",
    "scripts/living-repo.py",
    "scripts/motion-grammar.py",
    "scripts/pairwise-capture.py",
    "scripts/pareto-select.py",
    "scripts/perceptual-diff.py",
    "scripts/perceptual-ramps.py",
    "scripts/reduced-motion-gate.py",
    "scripts/reference-decompose-guard.py",
    "scripts/regression-firewall.py",
    "scripts/self-heal-guard.py",
    "scripts/selftest-roundtrip.sh",
    "scripts/spacing-hierarchy.py",
    "scripts/spine.py",
    "scripts/state-motion-req.py",
    "scripts/subtraction-pass.py",
    "scripts/sync-compiled.py",
    "scripts/synthesis-ladder.py",
    "scripts/taste-model.py",
    "scripts/token-lint.py",
    "scripts/type-conditional.py",
    "scripts/validate.sh",
    "scripts/verification-gate.py",
    "src/"
  ],
  "scripts": {
    "validate": "bash scripts/validate.sh",
    "sync-compiled": "python3 scripts/sync-compiled.py",
    "postcompile": "python3 scripts/sync-compiled.py && bash scripts/validate.sh",
    "selftest": "bash scripts/selftest-roundtrip.sh",
    "build-context": "python3 scripts/build-context.py",
    "mcp": "node mcp/guild-mcp.mjs",
    "canvas": "python3 scripts/guild-canvas.py --render",
    "canvas:watch": "python3 scripts/guild-canvas.py --watch",
    "prototype": "python3 scripts/guild-prototype-lane.py",
    "tokens-dtcg": "python3 scripts/cd-tokens-to-dtcg.py",
    "interop": "python3 scripts/dtcg-export.py --target all",
    "interop:check": "python3 scripts/dtcg-export.py --check",
    "handoff-gate": "python3 scripts/cd-handoff-gate.py --selftest",
    "jury": "python3 scripts/bradley-terry.py --selftest",
    "judge-cal": "python3 scripts/judge-calibration.py --selftest",
    "pareto": "python3 scripts/pareto-select.py --selftest",
    "self-heal-guard": "python3 scripts/self-heal-guard.py --selftest",
    "ab-eval": "python3 scripts/ab-eval.py --selftest",
    "type-conditional": "python3 scripts/type-conditional.py --selftest",
    "ramps": "python3 scripts/perceptual-ramps.py --selftest",
    "spacing": "python3 scripts/spacing-hierarchy.py --selftest",
    "subtract": "python3 scripts/subtraction-pass.py --selftest",
    "motion-grammar": "python3 scripts/motion-grammar.py --selftest",
    "reduced-motion": "python3 scripts/reduced-motion-gate.py --selftest",
    "state-motion": "python3 scripts/state-motion-req.py --selftest",
    "fidelity": "python3 scripts/fidelity-gate.py --selftest",
    "perceptual-diff": "python3 scripts/perceptual-diff.py --selftest",
    "token-lint": "python3 scripts/token-lint.py --selftest",
    "taste": "python3 scripts/taste-model.py --selftest",
    "regression-firewall": "python3 scripts/regression-firewall.py --selftest",
    "refdecomp-guard": "python3 scripts/reference-decompose-guard.py --selftest",
    "pick": "python3 scripts/pairwise-capture.py --selftest",
    "handoff-adapter": "python3 scripts/handoff-adapter.py --selftest",
    "spine": "python3 scripts/spine.py --selftest",
    "verify-gate": "python3 scripts/verification-gate.py --selftest",
    "confidence-gate": "python3 scripts/confidence-gate.py --selftest",
    "synthesis-ladder": "python3 scripts/synthesis-ladder.py --selftest",
    "living-repo": "python3 scripts/living-repo.py --selftest",
    "ia-guard": "python3 scripts/ia-evidence-guard.py --selftest",
    "artifact-model": "python3 scripts/artifact-model.py --selftest",
    "composers": "python3 scripts/composers.py --selftest",
    "layout-engine": "python3 scripts/layout-engine.py --selftest"
  },
  "keywords": [
    "design",
    "ux",
    "ui",
    "ai-agents",
    "claude-code",
    "bmad",
    "design-system",
    "figma",
    "product-design",
    "design-ops"
  ],
  "author": "Ayrehl Davis",
  "license": "MIT",
  "homepage": "https://github.com/ayesel/guild-bmad#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayesel/guild-bmad.git"
  },
  "bugs": {
    "url": "https://github.com/ayesel/guild-bmad/issues"
  },
  "engines": {
    "node": ">=16"
  }
}
